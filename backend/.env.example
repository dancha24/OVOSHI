# Django
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# Первый вход в /admin/: при старте контейнера создаётся суперпользователь, если его ещё нет
# OVOSHI_ADMIN_EMAIL=you@example.com
# OVOSHI_ADMIN_PASSWORD=secure-password
# OVOSHI_ADMIN_USERNAME=admin
# Только при DEBUG=1: разрешить любой Host (вебхук ВК за прокси с нестандартным Host)
# DJANGO_ALLOW_ALL_HOSTS=1
# В Docker entrypoint больше не вызывается makemigrations (стабильность). Нужно сгенерировать миграции вручную или:
# DJANGO_AUTOMAKEMIGRATIONS=1

# После логина редирект на фронт
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Прод (пример, NPM с SSL): FRONTEND_URL=https://ovoshipubgm.ru
# CORS_ORIGINS=...,http://ovoshipubgm.ru,https://ovoshipubgm.ru

# PostgreSQL (для локального запуска без Docker)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ovoshi
POSTGRES_USER=ovoshi
POSTGRES_PASSWORD=ovoshi

# OAuth — VK ID (как в Beats): PKCE, редирект на фронт /login, обмен кода на бэкенде /api/auth/vkid/complete/.
# Ключи в .env; при старте контейнера ensure_socialapps создаёт SocialApp «VK» в БД (для совместимости с allauth).
#
# Документация VK ID: https://id.vk.com/about/business/go/docs/ru/vkid/latest/vk-id/connection/create-application
# Тип: веб-приложение. Redirect URI в кабинете VK ID — URL страницы входа фронта (ровно так):
#   http://ovoshipubgm.ru/login   (или https://… если включён SSL)
# Локально (Vite :3000): http://localhost:3000/login
# Секрет приложения в обмене кода не используется (PKCE); VK_CLIENT_SECRET можно оставить пустым или заполнить для админки SocialApp.
#
# В рабочем backend/.env задайте:
#   VK_CLIENT_ID=...
#   VK_CLIENT_SECRET=...   (можно пусто для PKCE)
# Сборка фронта в Docker подставляет VITE_VK_ID из VK_CLIENT_ID, если запускать:
#   docker\dev.ps1 -Gateway up -d --build   (подключает --env-file ../backend/.env)
# или вручную: docker compose --env-file ../backend/.env -f docker-compose.yml -f docker-compose.domain.yml build --no-cache frontend
# Строка VITE_VK_ID в backend/.env для Docker-сборки не используется (только frontend/.env при локальном npm run dev).

# VK Callback API — https://dev.vk.com/ru/api/callback/getting-started
# Токен сообщества: Управление → Настройки → Работа с API → Ключи доступа (доступ к сообщениям).
VK_BOT_GROUP_TOKEN=
# Секретный ключ Callback: должен совпадать с полем в ВК. Если в сообществе секрет не задан — оставьте пустым.
VK_BOT_SECRET=
VK_BOT_CONFIRMATION=
VK_BOT_JOIN_URL=
VK_BOT_LEADER_LINK=
# Пусто — подставятся дефолты из settings (страницы ВК правил и набора)
VK_BOT_RULES_URL=
# Fallback для ссылки «напиши наборщику» в боте, если в настройках сайта (лидер) не задана «Ссылка на наборщика»
VK_BOT_RECRUITER_URL=
VK_BOT_ADMIN_VK_ID=
BACKEND_PUBLIC_URL=