# Опционально: docker/.env с VK_CLIENT_ID= — только если собираете без --env-file ../backend/.env.
# Удобнее: docker\up-prod.ps1 или dev.ps1 -Gateway (оба подключают backend/.env автоматически).
VK_CLIENT_ID=

# Только с dev.ps1 -Gateway -HotFrontend: переопределение HMR (если домен не ovoshipubgm.ru или NPM без SSL).
# VITE_HMR_HOST=your.domain
# VITE_HMR_PROTOCOL=wss
# VITE_HMR_CLIENT_PORT=443
